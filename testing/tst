import os
import time
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC


# CHANGE THESE PATHS TO YOUR IMAGE FILES
image_paths = [
    "images/product_0.jpg",
    "images/product_1.jpg"
]

# Convert to absolute paths
image_paths = [os.path.abspath(p) for p in image_paths]

print("Checking images...\n")

for p in image_paths:
    print(p, "exists:", os.path.exists(p))

print("\nOpening browser...")

options = webdriver.ChromeOptions()
options.add_argument("user-data-dir=chrome_profile")

driver = webdriver.Chrome(options=options)

driver.get("https://www.instagram.com")

input("\nLogin to Instagram and press ENTER...")

# Open create post page
driver.get("https://www.instagram.com/create/select/")

wait = WebDriverWait(driver, 30)

try:
    file_input = wait.until(
        EC.presence_of_element_located((By.CSS_SELECTOR, "input[type='file']"))
    )

    print("\nUploading images...")

    file_input.send_keys("\n".join(image_paths))

    print("Images uploaded successfully!")

except Exception as e:
    print("\nUpload failed:")
    print(e)

time.sleep(60)